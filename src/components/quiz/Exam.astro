---
import annexQuestionBank from '../../lib/data/annex-a-question-bank.json';
import ExamApp from './ExamApp';
import type { ExamQuestion } from './examTypes';

type RawQuestion = {
	id: string;
	section: string;
	mapRegion?: 'vancouver' | 'montreal';
	question: string;
	answer: string;
	choices?: Record<string, string>;
};

const CHOICE_KEYS = ['a', 'b', 'c', 'd'] as const;

const normalizeChoiceText = (text: string): string =>
	text
		.replace(/\s+/g, ' ')
		.replace(/^[:;,-]+\s*/, '')
		.trim();

const normalizeQuestion = (question: RawQuestion): ExamQuestion | null => {
	const answer = question.answer?.trim().toLowerCase();
	if (!CHOICE_KEYS.includes(answer as (typeof CHOICE_KEYS)[number])) {
		return null;
	}

	const sourceChoices = question.choices ?? null;
	if (!sourceChoices) {
		return null;
	}

	const choices = CHOICE_KEYS.map((value) => {
		const label = normalizeChoiceText(sourceChoices[value] ?? '');
		return {
			value,
			label,
		};
	});

	if (choices.some((choice) => choice.label.length === 0)) {
		return null;
	}

	const prompt = question.question.replace(/\s+/g, ' ').trim();
	const mapRegion = question.mapRegion ?? null;
	const isMapQuestion = mapRegion === 'vancouver';
	const multiline = /\bA\.\s+.*\bB\.\s+.*\bC\./.test(prompt);

	return {
		id: question.id,
		section: question.section,
		mapRegion,
		prompt,
		correctAnswer: answer as 'a' | 'b' | 'c' | 'd',
		choices,
		isMapQuestion,
		multiline,
	};
};

const examQuestionPool = (annexQuestionBank.questions as RawQuestion[])
	.map(normalizeQuestion)
	.filter((question): question is ExamQuestion => question !== null);
---

<section class="exam">
	<ExamApp client:load questionPool={examQuestionPool} />
</section>

<style is:global>
	@layer starlight.core {
		.exam {
			display: grid;
			gap: 1rem;
		}

		.exam .exam-intro,
		.exam .exam-run {
			border: 1px solid var(--sl-color-gray-5);
			border-radius: 0.85rem;
			padding: 1rem;
			background: color-mix(in srgb, var(--sl-color-gray-6) 40%, transparent);
		}

		.exam .exam-intro h2 {
			margin: 0 0 0.5rem;
		}

		.exam .exam-intro ul {
			margin: 0.5rem 0 0.9rem;
			padding-left: 1.2rem;
		}

		.exam .exam-toolbar {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 0.75rem;
			border: 1px solid var(--sl-color-gray-5);
			border-radius: 0.85rem;
			background: var(--sl-color-bg);
		}

		.exam .exam-timer-reminder {
			margin: 0;
			font-size: var(--sl-text-sm);
		}

		.exam .exam-vnc {
			margin-bottom: 0.9rem;
		}

		.exam .exam-vnc-viewer {
			margin-top: 0.6rem;
		}

		.exam .quiz {
			display: grid;
			gap: 0.75rem;
		}

		.exam .quiz-map-work {
			display: grid;
			gap: 0.75rem;
			margin-top: 0.6rem;
			padding-top: 0.9rem;
			border-top: 1px solid var(--sl-color-gray-5);
		}

		.exam .quiz-section-title {
			margin: 0;
			font-size: var(--sl-text-base);
			letter-spacing: 0.01em;
		}

		.exam .legend {
			float: left;
		}

		.exam .quiz-question {
			border: 1px solid var(--sl-color-gray-5);
			border-radius: 0.85rem;
			padding: 0.8rem 0.85rem;
			margin: 0;
			display: grid;
			gap: 0.65rem;
			background: color-mix(in srgb, var(--sl-color-gray-6) 50%, transparent);
			transition: padding 0.3s ease;
		}

		.exam .quiz-question-number {
			display: inline-block;
			font-size: var(--sl-text-xs);
			color: var(--sl-color-gray-3);
			text-transform: uppercase;
			letter-spacing: 0.06em;
		}

		.exam .quiz-question-prompt {
			display: block;
			margin-top: 0.2rem;
			font-size: var(--sl-text-sm);
			color: var(--sl-color-white);
			font-weight: 550;
			letter-spacing: 0.01em;
		}

		.exam .quiz-question[data-multiline='true'] .quiz-question-prompt {
			white-space: pre-wrap;
			font-weight: 400;
		}

		.exam .quiz-map-badge {
			display: inline-block;
			margin-top: 0.5rem;
			font-size: 0.68rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: #d7ffe9;
		}

		.exam .quiz-question-prompt p {
			margin: 0.35rem 0 0;
		}

		.exam .quiz-question-prompt p:first-child {
			margin-top: 0.25rem;
		}

		.exam .quiz-question-prompt .quiz-prompt-alpha-list,
		.exam .quiz-question-prompt .quiz-prompt-alpha-list li {
			font-weight: 400;
		}

		.exam .quiz-question[data-multiline='true'] .quiz-question-prompt .quiz-prompt-outro {
			font-weight: 550;
		}

		.exam .quiz-choices {
			display: grid;
		}

		.exam .quiz-choice {
			display: flex;
			align-items: center;
			gap: 0.45rem;
			padding: 0.48rem 0.6rem;
			border-radius: 0.6rem;
			border: 1px solid var(--sl-color-gray-5);
			background: color-mix(in srgb, var(--sl-color-bg) 84%, transparent);
			cursor: pointer;
			font-size: var(--sl-text-sm);
			line-height: 1.35;
		}

		.exam .quiz-choice:hover {
			border-color: color-mix(in srgb, var(--sl-color-accent) 52%, var(--sl-color-gray-4));
		}

		.exam .quiz-choice input[type='radio'] {
			margin: 0;
		}

		.exam .quiz-choice[data-state='correct'] {
			border-color: color-mix(in srgb, #6ee7a8 70%, var(--sl-color-gray-4));
			background: color-mix(in srgb, #6ee7a8 16%, var(--sl-color-bg));
		}

		.exam .quiz-choice[data-state='incorrect'] {
			border-color: color-mix(in srgb, #f87171 70%, var(--sl-color-gray-4));
			background: color-mix(in srgb, #f87171 14%, var(--sl-color-bg));
		}

		.exam .quiz-feedback {
			margin: 0;
			font-size: var(--sl-text-xs);
			border-radius: 0.55rem;
			display: grid;
			grid-template-rows: 0fr;
			transition: grid-template-rows 0.1s ease;
		}

		.exam .quiz-feedback span {
			overflow: hidden;
		}

		.exam .quiz-feedback[data-status='correct'],
		.exam .quiz-feedback[data-status='incorrect'] {
			grid-template-rows: 1fr;
			padding: 0.42rem 0.5rem;
		}

		.exam .quiz-feedback[data-status='correct'] {
			color: #d7ffe9;
			background: color-mix(in srgb, #6ee7a8 16%, var(--sl-color-bg));
		}

		.exam .quiz-feedback[data-status='incorrect'] {
			color: #ffd9d9;
			background: color-mix(in srgb, #f87171 16%, var(--sl-color-bg));
		}

		.exam .quiz-actions {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: 0.4rem;
		}

		.exam .quiz-score {
			margin: 0;
			font-size: var(--sl-text-xs);
			font-weight: 700;
			color: var(--sl-color-gray-2);
		}
	}
</style>
