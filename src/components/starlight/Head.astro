---
import { generateOGURL } from '../../lib/og.ts';

const { head } = Astro.locals.starlightRoute;
const currentPath = Astro.url.pathname;

// Automatically map current path to generated static image
const ogImagePath = generateOGURL(currentPath);

// Combine site origin with the static path
const ogImageURL = new URL(ogImagePath, Astro.site ?? Astro.url.origin).toString();
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

<!-- Dynamic Open Graph tags -->
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImageURL} />
