<section class="sync-manager" data-sync-manager>
	<h2>Sync Progress</h2>
	<p>
		Generate a link from this browser, then open it on another device to import your completed
		lessons.
	</p>
	<p class="sync-meta" data-sync-meta>
		Completed lessons: 0
	</p>
	<div class="sync-actions">
		<button type="button" data-generate-link>Generate Sync Link</button>
		<button type="button" data-copy-link disabled>
			Copy Link
		</button>
	</div>
	<textarea readonly rows="4" data-sync-link placeholder="Generate a link to sync your progress"></textarea>
</section>

<script>
	import { $progress } from '../../lib/stores/progressStore';
	import { createSyncLink } from '../../lib/progress/sync';

	const root = document.querySelector('[data-sync-manager]');
	if (!root) {
		throw new Error('Sync manager root not found');
	}

	const meta = root.querySelector('[data-sync-meta]');
	const generateButton = root.querySelector('[data-generate-link]');
	const copyButton = root.querySelector('[data-copy-link]');
	const output = root.querySelector('[data-sync-link]');

	if (
		!(meta instanceof HTMLElement) ||
		!(generateButton instanceof HTMLButtonElement) ||
		!(copyButton instanceof HTMLButtonElement) ||
		!(output instanceof HTMLTextAreaElement)
	) {
		throw new Error('Sync manager UI did not initialize');
	}

	const renderMeta = () => {
		meta.textContent = `Completed lessons: ${$progress.get().completedLessons.length}`;
	};

	renderMeta();
	$progress.listen(renderMeta);

	generateButton.addEventListener('click', async () => {
		try {
			generateButton.disabled = true;
			generateButton.textContent = 'Generating...';
			output.value = await createSyncLink(window.location.origin, $progress.get());
			copyButton.disabled = output.value.length === 0;
		} catch {
			output.value = 'Failed to generate sync link';
			copyButton.disabled = true;
		} finally {
			generateButton.disabled = false;
			generateButton.textContent = 'Generate Sync Link';
		}
	});

	copyButton.addEventListener('click', async () => {
		if (!output.value) return;
		try {
			await navigator.clipboard.writeText(output.value);
			copyButton.textContent = 'Copied';
			window.setTimeout(() => {
				copyButton.textContent = 'Copy Link';
			}, 1000);
		} catch {
			copyButton.textContent = 'Copy failed';
			window.setTimeout(() => {
				copyButton.textContent = 'Copy Link';
			}, 1200);
		}
	});
</script>

<style>
	.sync-manager {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.75rem;
		padding: 1rem;
		background: color-mix(in srgb, var(--sl-color-gray-6) 60%, transparent);
	}

	.sync-manager h2 {
		margin: 0 0 0.5rem;
	}

	.sync-manager p {
		margin: 0 0 0.75rem;
	}

	.sync-meta {
		color: var(--sl-color-gray-2);
		font-size: var(--sl-text-sm);
	}

	.sync-actions {
		display: flex;
		gap: 0.6rem;
		margin-bottom: 0.75rem;
		flex-wrap: wrap;
	}

	.sync-actions button {
		border: 1px solid var(--sl-color-gray-4);
		border-radius: 0.65rem;
		padding: 0.45rem 0.75rem;
		font-size: var(--sl-text-xs);
		font-weight: 600;
		cursor: pointer;
		background: color-mix(in srgb, var(--sl-color-gray-6) 50%, transparent);
		color: var(--sl-color-white);
	}

	.sync-actions button:disabled {
		opacity: 0.55;
		cursor: not-allowed;
	}

	.sync-manager textarea {
		width: 100%;
		border-radius: 0.65rem;
		border: 1px solid var(--sl-color-gray-4);
		padding: 0.65rem;
		font-size: var(--sl-text-xs);
		background: color-mix(in srgb, var(--sl-color-gray-6) 40%, transparent);
		color: var(--sl-color-white);
	}
</style>
