<section class="sync-manager" data-sync-manager>
	<h2>Resume Progress</h2>
	<p class="sync-meta" data-sync-meta>
		Completed lessons: 0
	</p>
	<div class="sync-actions">
		<button type="button" class="btn-primary" data-copy-link>Copy Link</button>
	</div>
</section>

<script>
	import { $progress } from '../../lib/stores/progressStore';
	import { createSyncLink } from '../../lib/progress/sync';

	const root = document.querySelector('[data-sync-manager]');
	if (!root) {
		throw new Error('Sync manager root not found');
	}

	const meta = root.querySelector('[data-sync-meta]');
	const copyButton = root.querySelector('[data-copy-link]');

	if (
		!(meta instanceof HTMLElement) ||
		!(copyButton instanceof HTMLButtonElement)
	) {
		throw new Error('Sync manager UI did not initialize');
	}

	const copyIcon =
		'<svg class="sync-icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 4h3a1 1 0 0 1 1 1v15a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h3m0 3h6m-6 5h6m-6 4h6M10 3v4h4V3h-4Z"/></svg>';
	const copiedIcon =
		'<svg class="sync-icon sync-icon--copied" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 4h3a1 1 0 0 1 1 1v15a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h3m0 3h6m-6 7 2 2 4-4m-5-9v4h4V3h-4Z"/></svg>';

	const setCopyButtonLabel = (
		state: 'copy' | 'copied' | 'failed'
	) => {
		switch (state) {
			case 'copied':
				copyButton.innerHTML = `${copiedIcon}<span>Copied</span>`;
				break;
			case 'failed':
				copyButton.innerHTML = `${copyIcon}<span>Copy failed</span>`;
				break;
			default:
				copyButton.innerHTML = `${copyIcon}<span>Copy Link</span>`;
		}
	};

	const renderMeta = () => {
		meta.textContent = `Completed lessons: ${$progress.get().completedLessons.length}`;
	};

	renderMeta();
	$progress.listen(renderMeta);
	setCopyButtonLabel('copy');

	let copyStatusResetTimer: number | null = null;

	const queueCopyButtonReset = (delayMs = 750) => {
		if (copyStatusResetTimer !== null) {
			window.clearTimeout(copyStatusResetTimer);
		}

		copyStatusResetTimer = window.setTimeout(() => {
			setCopyButtonLabel('copy');
			copyButton.disabled = false;
			copyStatusResetTimer = null;
		}, delayMs);
	};

	window.addEventListener(
		'pagehide',
		() => {
			if (copyStatusResetTimer !== null) {
				window.clearTimeout(copyStatusResetTimer);
				copyStatusResetTimer = null;
			}
		},
		{ once: true }
	);

	copyButton.addEventListener('click', async () => {
		try {
			copyButton.disabled = true;
			const syncLink = await createSyncLink(window.location.origin, $progress.get());
			await navigator.clipboard.writeText(syncLink);
			setCopyButtonLabel('copied');
			queueCopyButtonReset();
		} catch {
			setCopyButtonLabel('failed');
			queueCopyButtonReset();
		}
	});
</script>

<style>
	.sync-manager {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.75rem;
		padding: 1rem;
		background: color-mix(in srgb, var(--sl-color-gray-6) 60%, transparent);
	}

	.sync-manager h2 {
		margin: 0 0 0.5rem;
	}

	.sync-manager p {
		margin: 0 0 0.75rem;
	}

	.sync-meta {
		color: var(--sl-color-gray-2);
		font-size: var(--sl-text-sm);
	}

	.sync-actions {
		display: flex;
		gap: 0.6rem;
		margin-bottom: 0.75rem;
		flex-wrap: wrap;
	}

	.sync-icon {
		width: 1rem;
		height: 1rem;
		flex: 0 0 auto;
	}

	.sync-icon--copied {
		color: var(--sl-color-accent-high);
	}
</style>
